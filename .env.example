# Copy to `.env.local` for local development (never commit real secrets).
# Vercel: set the same variable names under Project → Settings → Environment Variables.

# --- Database (Prisma, PostgreSQL) ---
# Local: e.g. postgresql://USER:PASS@localhost:5432/hetaobook_dev?schema=public
# Neon: use the connection strings from the Neon dashboard (pooled + direct).
DATABASE_URL=
DIRECT_URL=

# --- App URL (optional locally; set in Vercel for server-side fetches in prod) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- BigModel / 智谱 (AI grading) ---
# Example base: https://open.bigmodel.cn/api/paas/v4  (no trailing slash required)
ZAI_BASE_URL=
ZAI_API_KEY=
# Optional, used only if you generate .z-ai-config via scripts/generate-ai-config.mjs
ZAI_CHAT_ID=
ZAI_USER_ID=

# --- Feishu (spreadsheet push / permissions) ---
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Spreadsheet token from the sheet URL (the id segment before ?)
FEISHU_SPREADSHEET_TOKEN=
# Legacy alias supported by code; prefer FEISHU_SPREADSHEET_TOKEN
# FEISHU_SHEET_TOKEN=

# Optional: default https://open.feishu.cn
# FEISHU_BASE_URL=

# Optional: drive doc token for permission APIs if different from the sheet
# FEISHU_PERMISSION_TOKEN=

# Optional: grant-admin helper (see src/lib/feishu/permission.ts)
# FEISHU_ADMIN_MEMBER_ID=
# FEISHU_ADMIN_MEMBER_TYPE=email
